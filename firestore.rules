# Firebase Security Rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function getArea() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.area;
    }

    // Users Profile Collection
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Complaints Collection
    match /complaints/{complaintId} {
      // Anyone logged in can read complaints (for the public feed)
      allow read: if request.auth != null;
      
      // Users can only create complaints tied to their own UID
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Secure Update Rules
      allow update: if request.auth != null && (
        // 1. You are the original creator
        resource.data.userId == request.auth.uid || 
        // 2. You are just toggling the upvoters array (Voting)
        request.resource.data.diff(resource.data).affectedKeys() == ['upvoters'].toSet() ||
        // 3. You are a Mayor and your area precisely matches the complaint's area
        (getRole() == 'mayor' && getArea() == resource.data.area)
      );
      
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Role-Based Admin Access configuration lock
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  }
}
